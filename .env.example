# ============================================================
# POLYMARKET — Credenciais da API (obrigatório)
# Gere em: https://polymarket.com → Settings → API Keys
# ============================================================

# Chave privada da carteira Polygon (sem o prefixo 0x)
POLYMARKET_PK=

# Credenciais da API CLOB
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Endereço da carteira Polygon (funder address, com 0x)
POLYMARKET_FUNDER=

# ============================================================
# REDIS — Controle de modo sim/live em tempo real (opcional)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# ============================================================
# BOT — Parâmetros de risco e execução (opcional)
# ============================================================
# Tamanho da aposta em USD. Knob ÚNICO: vale no dry-run (valor gravado no
# tv_dry_run_trades.json) E no live (valor real da ordem, via patch_market_orders),
# e os caps do risk engine escalam com ele (max_position=valor, exposição/perda
# diária = 5x). Mude aqui e reinicie o bot — sem editar código. Default 1.
MARKET_BUY_USD=1
STOP_LOSS_PCT=0.30
TAKE_PROFIT_PCT=0.20
SPIKE_THRESHOLD=0.15
DIVERGENCE_THRESHOLD=0.05

# ============================================================
# GRAFANA — Painel de monitoramento (opcional)
# ============================================================
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASS=admin

# ============================================================
# DADOS EXTERNOS — APIs opcionais
# ============================================================
CRYPTOPANIC_API_KEY=

# Telegram Bot (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# TRADINGVIEW — Estratégia via webhook (opcional)
# ============================================================
TRADINGVIEW_WEBHOOK_PORT=8001
TRADINGVIEW_WEBHOOK_SECRET=
TRADINGVIEW_SIGNAL_CONFIDENCE=0.75
TRADINGVIEW_SIGNAL_TTL_SECONDS=30

# --- Gate de book + conviction sizing (compartilhado bot<->backtest) ---
# Floor: pula o trade se a prob implícita do lado comprado (p_side) < este valor.
# 0.42 = config de PnL máximo do `backtest tune` (produção). 0 = desliga o gate.
TV_MIN_BOOK_PROB=0.42
TV_SIZE_FULL_PROB=0.55
TV_SIZE_MIN_FRAC=1.0

# --- Filtro de sessão + faixa de prob (NOVO, opt-in, default OFF) ---
# Motivado pelo post-mortem dos losses (.context/docs/tv-loss-postmortem-findings.md):
# a edge concentra na sessão EU (08-16 UTC) e na faixa p_side 0.42-0.50.
#
#   TV_TRADE_HOURS  : whitelist de horas UTC. Vazio = todas (sem filtro).
#                     Ex.: "8-15" = sessão EU; aceita lista/ranges "0,4,8-10".
#   TV_MAX_BOOK_PROB: teto da faixa de entrada. 1.0 = sem teto (off).
#                     Com TV_MIN_BOOK_PROB forma a banda (floor 0.42 + teto 0.50 = 0.42-0.50).
#
# Para LIGAR o filtro EU + faixa 0.42-0.50 (validar OOS antes — n>=200 / walk-forward!):
#   TV_TRADE_HOURS=8-15
#   TV_MAX_BOOK_PROB=0.50
TV_TRADE_HOURS=
TV_MAX_BOOK_PROB=1.0

# ============================================================
# SINAL LOCAL — Gerador Guppy RSI (substitui o webhook do TradingView)
# ============================================================
# local_signal_generator.py replica o indicador Pine localmente a partir de
# klines da Binance e publica na MESMA fila (btc_trading:tradingview_signals).
# Reaproveita todo o caminho de trade (N+1, gate de book, sizing, dry-run) e os
# knobs TV_* acima. Runbook: .context/docs/local-signal-runbook.md
#
# EXCLUSIVIDADE: rode ESTE *ou* o tradingview_webhook_receiver — NUNCA os dois
# alimentando a fila (disparo duplicado). active_strategy deve ser "tradingview".
LOCAL_SIGNAL_SYMBOL=BTCUSDT
LOCAL_SIGNAL_INTERVAL=15m
